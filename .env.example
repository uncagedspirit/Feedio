# ─── SUPABASE ────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── APP URL (used for payment redirect URLs) ────────────────────────────────
# Local dev:
VITE_APP_URL=http://localhost:5173
# Production:
# VITE_APP_URL=https://yourapp.com

# ─── DODO PAYMENTS (server-side only — never exposed to the frontend) ─────────
# Dodo Payments API keys live exclusively in Supabase Edge Function secrets.
# Set them via: supabase secrets set DODO_API_KEY=your-key-here
#
# Required edge function secrets (set in Supabase Dashboard → Edge Functions → Secrets):
#   DODO_API_KEY=your-dodo-api-key
#   DODO_WEBHOOK_SECRET=your-dodo-webhook-secret
#   SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  (Supabase → Settings → API)