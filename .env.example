# ─── SUPABASE ────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── STRIPE ──────────────────────────────────────────────────────────────────
# Publishable key from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# Pro plan price ID from: https://dashboard.stripe.com/products
# Create a "Pro" product with a $19/month recurring price and paste the price ID here
VITE_STRIPE_PRO_PRICE_ID=price_your-price-id-here

# ─── APP URL (used for Stripe success/cancel redirects) ─────────────────────
# Local dev:
VITE_APP_URL=http://localhost:5173
# Production:
# VITE_APP_URL=https://yourapp.com

# ─── SUPABASE EDGE FUNCTIONS (set these in Supabase Dashboard → Edge Functions → Secrets) ─
# These are NOT prefixed with VITE_ — they live server-side only
# STRIPE_SECRET_KEY=sk_test_your-secret-key
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key (from Supabase → Settings → API)
